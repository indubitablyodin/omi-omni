# Omi Omni Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================
BACKEND_PORT=8000
API_KEY=your-secure-api-key-here-change-this
DEBUG=true

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
POSTGRES_DB=omi
POSTGRES_USER=omi
POSTGRES_PASSWORD=change-this-password
POSTGRES_PORT=5432
POSTGRES_HOST=postgres

# =============================================================================
# SPEECH-TO-TEXT (Faster Whisper)
# =============================================================================
WHISPER_PORT=8001
WHISPER_MODEL=Systran/faster-whisper-large-v3
WHISPER_URL=http://whisper:8000
WHISPER_COMPUTE_TYPE=float16

# =============================================================================
# LLM (Ollama)
# =============================================================================
OLLAMA_PORT=11434
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_KEEP_ALIVE=24h
OLLAMA_MAX_LOADED_MODELS=2

# =============================================================================
# VECTOR DATABASE (Qdrant)
# =============================================================================
QDRANT_PORT=6333
QDRANT_HOST=qdrant
QDRANT_API_KEY=
QDRANT_COLLECTION=memories

# =============================================================================
# OBJECT STORAGE (MinIO)
# =============================================================================
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=minio
MINIO_SECURE=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-password
MINIO_BUCKET_AUDIO=omi-audio
MINIO_BUCKET_PROFILES=omi-profiles
MINIO_BUCKET_BACKUPS=omi-backups

# =============================================================================
# CACHE (Redis)
# =============================================================================
REDIS_PORT=6379
REDIS_HOST=redis
REDIS_PASSWORD=change-this-password

# =============================================================================
# SEARCH (Meilisearch)
# =============================================================================
MEILISEARCH_PORT=7700
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_KEY=change-this-key

# =============================================================================
# AMD GPU CONFIGURATION (for RX 7900 XTX and other AMD GPUs)
# =============================================================================
# Uncomment and set these if using AMD GPU
# HSA_OVERRIDE_GFX_VERSION=10.3.0
# ROCM_PATH=/opt/rocm
# HIP_PATH=/opt/rocm

# =============================================================================
# DOCKER NETWORK
# =============================================================================
DOCKER_NETWORK=omi-network

# =============================================================================
# MOBILE APP CONFIGURATION
# =============================================================================
# These are used by the Flutter app
MOBILE_API_BASE_URL=http://localhost:8000
MOBILE_API_KEY=${API_KEY}

# =============================================================================
# FIRMWARE BUILD CONFIGURATION
# =============================================================================
FIRMWARE_BUILD_DIR=firmware/omi/build
FIRMWARE_OUTPUT_DIR=firmware/omi/build/docker_build

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# Maximum audio chunk size for WebSocket (bytes)
MAX_AUDIO_CHUNK_SIZE=4096

# Timeout for transcription (seconds)
TRANSCRIPTION_TIMEOUT=120

# Timeout for LLM generation (seconds)
LLM_TIMEOUT=300

# Maximum conversation length for processing (minutes)
MAX_CONVERSATION_LENGTH=60
