# Omi Omni - Apple Silicon (M4 MacBook Air) Configuration
# Lightweight configuration optimized for low RAM usage

# API Authentication
API_KEY=change-me-to-a-secure-random-key

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=omi
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=omi

# Object Storage (MinIO)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_BUCKET=audio

# Vector Database (Qdrant)
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Cache (Redis)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Search (Meilisearch)
MEILI_HOST=meilisearch
MEILI_PORT=7700
MEILI_MASTER_KEY=change-me-meili-key

# AI Services - Lightweight models for Apple Silicon
WHISPER_HOST=whisper
WHISPER_PORT=8001
WHISPER_MODEL=Systran/faster-whisper-small
WHISPER_MODEL_PATH=/models/ggml-small.bin

OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODELS_PATH=/root/.ollama/models

# Backend - Lightweight configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_API_KEY=$(API_KEY)

# Model Tier Configuration
MODEL_TIER=lightweight
LLM_MODEL=qwen2.5:0.5b

# Resource Limits for MacBook Air
OLLAMA_MAX_VRAM=2gb
OLLAMA_MAX_LOADED_MODELS=1
